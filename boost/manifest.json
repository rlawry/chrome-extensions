{
  "manifest_version": 3,
  "name": "YouTube Volume Boost",
  "version": "1.1.0",
  "description": "Adds a gain boost control for YouTube videos.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://music.youtube.com/*"
  ],
  "action": {
    "default_title": "YouTube Volume Boost",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://music.youtube.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
